{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./src/*"]
    },

    "allowSyntheticDefaultImports": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "noEmit": true,

    "isolatedModules": true
  },

  "include": [
    "src/**/*",
    "App.tsx"
  ],

  "exclude": [
    "node_modules"
  ]
}